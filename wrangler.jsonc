{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "marzy-site",
  "compatibility_date": "2025-05-01",
  "main": "worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "html_handling": "drop-trailing-slash",
    "not_found_handling": "404-page"
  }
}
